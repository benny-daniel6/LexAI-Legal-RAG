# ── LLM Settings ──────────────────────────────────────────────────────────────
# Path to your GGUF model file (Gemma 2 2B Q4_K_M or your fine-tuned export)
MODEL_PATH=./models/gemma-2-2b-it-Q4_K_M.gguf

# LLM backend: "local" (llama-cpp) or "gemini" (Gemini API fallback)
LLM_BACKEND=local
LLM_API_URL=http://localhost:8080/v1

# Context window tokens for llama-cpp
MODEL_CTX=4096

# Number of CPU threads to use for inference (set to your core count)
MODEL_THREADS=8

# ── Gemini API (only needed if LLM_BACKEND=gemini) ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── HuggingFace (needed to download base Gemma for fine-tuning) ───────────────
HF_TOKEN=your_hf_token_here

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ── Embedding Model (downloaded automatically on first run) ───────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── RAG Settings ──────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=6
CONFIDENCE_THRESHOLD=0.45
MAX_ANSWER_TOKENS=512
